    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagentid/agent-id-js"
  },
  "homepage": "https://openagentid.org",
  "keywords": [
    "agent",
