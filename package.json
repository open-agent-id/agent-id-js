{
  "name": "@open-agent-id/sdk",
  "version": "0.2.1",
  "description": "JavaScript/TypeScript SDK for Open Agent ID — register, sign, and verify AI agent identities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
